{
  "editor.codeActionsOnSave": {
    "source.addMissingImports": "explicit",
    "source.fixAll.eslint": "explicit"
  },
  "files.eol": "\n",
  "files.autoSave": "afterDelay",
  "files.autoSaveDelay": 100,
  "eslint.runtime": "node",
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnType": false,
  "editor.formatOnPaste": false,
  "editor.formatOnSave": true,
  "editor.rulers": [200],
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  //"editor.wordWrap": "off",
  "editor.renderControlCharacters": true,
  "editor.quickSuggestions": {
    "comments": false
  },
  "prettier.singleQuote": true,
  "prettier.printWidth": 80,
  "prettier.semi": true,
  "prettier.tabWidth": 2,
  "prettier.ignorePath": ".gitignore",
  "css.lint.unknownAtRules": "ignore",
  "redhat.telemetry.enabled": false,
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.patterns": {
    "*.ts": "${capture}.js, ${capture}.typegen.ts",
    "*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts",
    "*.jsx": "${capture}.js",
    "*.tsx": "${capture}.ts, ${capture}.typegen.ts",
    "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, pnpm-workspace.yaml, .eslintrc.json, next.config.mjs, postcss.config.mjs, tailwind.config.ts, tsconfig.json, next-env.d.ts, .gitignore, next.config.ts, .eslintrc.cjs, .env, .env.example, eslint.config.mjs, eslint.config.js, .lintstagedrc, .prettierrc, .prettierrc.mjs, .prettierignore, .editorconfig, .tool-versions, babel.config.cjs, jest.config.js, mise.toml, LICENSE",
    "*.mts": "${capture}.typegen.ts",
    "*.cts": "${capture}.typegen.ts"
  },
  "search.exclude": {
    "**/node_modules": true
  },
  "[prisma]": {
    "editor.defaultFormatter": "Prisma.prisma"
  },
  "tailwindCSS.experimental.classRegex": [
    ["cva\\(([^)]*)\\)", "[\"'`]([^\"'`]*).*?[\"'`]"],
    ["cx\\(([^)]*)\\)", "(?:'|\"|`)([^']*)(?:'|\"|`)"],
    ["twMerge\\(([^)]*)\\)", "[\"'`]([^\"'`]*).*?[\"'`]"],
    [
      "createTheme(?:<\\w+>)?\\s*\\(([^)]*)\\)",
      "{?\\s?[\\w].*:\\s*?[\"'`]([^\"'`]*).*?,?\\s?}?"
    ]
  ],
  "tailwind-fold.autoFold": true,
  "typescript.enablePromptUseWorkspaceTsdk": true,
  "typescript.tsdk": "node_modules/typescript/lib",
  "typescript.preferences.importModuleSpecifier": "non-relative",
  "eslint.options": {
    "overrideConfigFile": "eslint.config.mjs"
  },
  // Windows GitBash
  "terminal.integrated.defaultProfile.windows": "Git Bash",
  // Windowsのデフォルトターミナル
  //"terminal.integrated.defaultProfile.windows": "PowerShell",
  // cmd.exeの場合
  // "terminal.integrated.defaultProfile.windows": "Command Prompt",
  // Linux
  "terminal.integrated.defaultProfile.linux": "bash",
  // macOS Catalina以降
  "terminal.integrated.defaultProfile.osx": "zsh",
  "files.associations": {
    "*.css": "tailwindcss"
  },
  "tailwindCSS.classAttributes": ["class", "className", "theme"]
}
